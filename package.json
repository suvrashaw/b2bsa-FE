{
  "name": "b2bsa-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run partytown:copy && next build && next-sitemap",
    "start": "next start",
    "lint": "eslint --config configs/eslint.config.mjs",
    "lint:styles": "stylelint --config configs/.stylelintrc.json \"src/**/*.css\"",
    "lint:duplication": "jscpd src",
    "lint:dead": "knip --config configs/knip.json",
    "partytown:copy": "partytown copylib public/~partytown",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "typecheck": "tsc --noEmit --incremental false",
    "check": "npm run format:check && npm run lint && npm run lint:styles && npm run typecheck && npm run lint:dead && npm run build",
    "analyze": "ANALYZE=true npm run build",
    "knip": "knip --config configs/knip.json",
    "audit": "lighthouse http://localhost:3000 --output html --output-path ./reports/lighthouse-report.html --view",
    "test": "playwright test --config configs/playwright.config.ts",
    "test:ui": "playwright test --config configs/playwright.config.ts --ui"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@qwik.dev/partytown": "^0.14.0",
    "@radix-ui/react-accordion": "^1.2.14",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-slot": "^1.3.0",
    "@sentry/nextjs": "^10.61.0",
    "@vercel/og": "^0.11.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.0",
    "lenis": "^1.3.24",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.80.0",
    "react-simple-maps": "^3.0.0",
    "sharp": "^0.35.2",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^5.9.3",
    "@next/bundle-analyzer": "^16.2.9",
    "@next/eslint-plugin-next": "^16.2.9",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-simple-maps": "^3.0.6",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-compat": "^7.0.2",
    "eslint-plugin-depend": "^1.5.0",
    "eslint-plugin-import-x": "^4.17.0",
    "eslint-plugin-jsonc": "^3.2.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-n": "^18.2.0",
    "eslint-plugin-no-constructor-bind": "^2.0.4",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-no-use-extend-native": "^0.7.3",
    "eslint-plugin-perfectionist": "^5.9.1",
    "eslint-plugin-playwright": "^2.10.4",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-perf": "^3.3.3",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-sonarjs": "^4.1.0",
    "eslint-plugin-tailwindcss": "^4.0.4",
    "eslint-plugin-unicorn": "^69.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-validate-jsx-nesting": "^0.1.1",
    "jscpd": "^5.0.11",
    "knip": "^6.20.0",
    "lighthouse": "^13.4.0",
    "next-sitemap": "^4.2.3",
    "prettier": "^3.8.4",
    "stylelint": "^17.14.0",
    "stylelint-config-clean-order": "^10.0.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-declaration-block-no-ignored-properties": "^3.0.0",
    "stylelint-high-performance-animation": "^2.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-prettier": "^5.0.3",
    "tailwindcss": "^4",
    "typescript": "^6",
    "typescript-eslint": "^8"
  },
  "browserslist": [
    ">0.3%",
    "not dead",
    "not op_mini all"
  ],
  "prettier": {
    "semi": true,
    "singleQuote": false,
    "tabWidth": 2,
    "trailingComma": "es5",
    "printWidth": 100,
    "bracketSpacing": true,
    "arrowParens": "always"
  },
  "jscpd": {
    "threshold": 5,
    "minLines": 15,
    "minTokens": 100,
    "reporters": [
      "html",
      "console"
    ],
    "output": "reports/jscpd",
    "gitignore": true,
    "ignore": [
      "**/*.d.ts",
      "**/*.json",
      "**/*.lock",
      "**/node_modules/**",
      "**/.next/**",
      "**/out/**",
      "**/build/**",
      "**/public/**",
      "**/reports/**"
    ]
  },
  "overrides": {
    "postcss": "^8.5.15",
    "d3-color": "^3.1.0",
    "@opentelemetry/core": "^2.8.0"
  }
}
